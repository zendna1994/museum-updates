<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZEN DNA | Admin Control</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; user-select: none; }
        .nav-bar { background: #002147; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; }
        .container { max-width: 1100px; margin: 20px auto; padding: 0 15px; }
        
        /* Stats Grid */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); text-align: center; border-bottom: 4px solid #3498db; }
        .stat-card h3 { margin: 0; font-size: 14px; color: #7f8c8d; text-transform: uppercase; }
        .stat-card p { margin: 10px 0 0; font-size: 28px; font-weight: bold; color: #002147; }

        /* Tables & Cards */
        .card { background: white; padding: 20px; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px; }
        .search-box { padding: 10px; border: 1px solid #ddd; border-radius: 6px; width: 250px; outline: none; }
        
        .table-wrapper { overflow-x: auto; max-height: 400px; border: 1px solid #eee; border-radius: 8px; }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { background: #f8f9fa; color: #2c3e50; padding: 12px; text-align: left; position: sticky; top: 0; border-bottom: 2px solid #eee; }
        td { padding: 12px; border-bottom: 1px solid #eee; color: #444; }
        tr:hover { background: #f1f7ff; }

        /* Loader */
        #loader { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.8); z-index: 9999; justify-content: center; align-items: center; flex-direction: column; }
        .spinner { width: 50px; height: 50px; border: 5px solid #f3f3f3; border-top: 5px solid #002147; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        .btn-logout { background: #e74c3c; color: white; border: none; padding: 8px 15px; border-radius: 5px; cursor: pointer; }
        .btn-refresh { background: #27ae60; color: white; border: none; padding: 8px 15px; border-radius: 5px; cursor: pointer; margin-right: 10px; }
    </style>
</head>
<body oncontextmenu="return false;">

<div id="loader">
    <div class="spinner"></div>
    <p>Syncing Management Data...</p>
</div>

<div class="nav-bar">
    <div style="font-weight: bold; font-size: 1.2rem;">ZEN DNA | Admin Portal</div>
    <div>
        <button class="btn-refresh" onclick="fetchData()">🔄 Refresh</button>
        <button class="btn-logout" onclick="logout()">Logout</button>
    </div>
</div>

<div class="container">
    <div class="stats-grid">
        <div class="stat-card"><h3>Total Students</h3><p id="countUsers">0</p></div>
        <div class="stat-card" style="border-color: #27ae60;"><h3>Total Specimens</h3><p id="countSpecimens">0</p></div>
        <div class="stat-card" style="border-color: #e74c3c;"><h3>Lifetime Scans</h3><p id="countLogs">0</p></div>
    </div>

    <div class="card">
        <h2 style="font-size: 18px; margin-top: 0;">System Growth Analysis</h2>
        <canvas id="adminChart" height="100"></canvas>
    </div>

    <div class="card">
        <div class="table-header">
            <h2 style="font-size: 18px; margin: 0;">User Access Control</h2>
            <input type="text" class="search-box" onkeyup="filterTable('userTable', 4)" placeholder="🔎 Search by Name...">
        </div>
        <div class="table-wrapper"><table id="userTable"></table></div>
    </div>

    <div class="card">
        <div class="table-header">
            <h2 style="font-size: 18px; margin: 0;">Live Scan Logs</h2>
            <input type="text" class="search-box" onkeyup="filterTable('logTable', 2)" placeholder="🔎 Filter by Student ID...">
        </div>
        <div class="table-wrapper"><table id="logTable"></table></div>
    </div>

    <div class="card">
        <div class="table-header">
            <h2 style="font-size: 18px; margin: 0;">Specimen Database</h2>
            <input type="text" class="search-box" onkeyup="filterTable('specimenTable', 1)" placeholder="🔎 Search Scientific Name...">
        </div>
        <div class="table-wrapper"><table id="specimenTable"></table></div>
    </div>
</div>

<script>
    const API = "https://script.google.com/macros/s/AKfycbz_bifFkLBL2Wbv8snnRhRwqyt4AJGyqfvcoK3elir9sbMu5OSlpTk_KbDAVwxgem-V/exec";
    const KEY = "ZEN_DNA_2026";

    // 1. SECURITY REDIRECT
    let user = JSON.parse(localStorage.getItem("user"));
    if(!user || parseInt(user.role) < 2) {
        alert("Unauthorized Access. Returning to login.");
        window.location = "login.html";
    }

    // 2. DATA FETCHING
    async function fetchData() {
        document.getElementById('loader').style.display = "flex";
        try {
            const response = await fetch(`${API}?action=fullData&key=${KEY}`);
            const res = await response.json();
            
            if(res.status === "success") {
                updateUI(res);
            }
        } catch (e) {
            console.error(e);
            alert("Error connecting to server.");
        }
        document.getElementById('loader').style.display = "none";
    }

    function updateUI(res) {
        // Update Stats
        document.getElementById('countUsers').innerText = res.users.length - 1;
        document.getElementById('countSpecimens').innerText = res.specimens.length - 1;
        document.getElementById('countLogs').innerText = res.logs.length - 1;

        // Render Tables
        renderTable('userTable', res.users);
        renderTable('logTable', res.logs);
        renderTable('specimenTable', res.specimens);

        // Render Chart
        const ctx = document.getElementById('adminChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Users', 'Specimens', 'Scans'],
                datasets: [{
                    label: 'System Count',
                    data: [res.users.length-1, res.specimens.length-1, res.logs.length-1],
                    backgroundColor: ['#3498db', '#27ae60', '#e74c3c']
                }]
            },
            options: { responsive: true, plugins: { legend: { display: false } } }
        });
    }

    function renderTable(id, data) {
        let table = document.getElementById(id);
        let html = "<thead><tr>";
        data[0].forEach(h => html += `<th>${h}</th>`);
        html += "</tr></thead><tbody>";
        for(let i=1; i<data.length; i++) {
            html += "<tr>";
            data[i].forEach(cell => html += `<td>${cell}</td>`);
            html += "</tr>";
        }
        html += "</tbody>";
        table.innerHTML = html;
    }

    function filterTable(tId, colIdx) {
        let input = event.target.value.toUpperCase();
        let rows = document.getElementById(tId).getElementsByTagName("tr");
        for (let i = 1; i < rows.length; i++) {
            let cell = rows[i].getElementsByTagName("td")[colIdx];
            if (cell) {
                rows[i].style.display = cell.innerText.toUpperCase().indexOf(input) > -1 ? "" : "none";
            }
        }
    }

    function logout() {
        localStorage.clear();
        window.location = "login.html";
    }

    // Load data on start
    fetchData();

    // Disable Inspect
    document.onkeydown = (e) => { if(e.keyCode == 123 || (e.ctrlKey && e.shiftKey && e.keyCode == 73)) return false; };
</script>

</body>
</html>
